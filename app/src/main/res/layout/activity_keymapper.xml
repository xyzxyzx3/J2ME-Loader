<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layoutDirection="ltr"
        android:fillViewport="true"
        android:fitsSystemWindows="true"
        tools:targetApi="jelly_bean_mr1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- 🔢 NUMERIC BUTTONS (MOVED UP - unchanged content) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/virtual_key_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virtual_key_1"/>

                <Button
                    android:id="@+id/virtual_key_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virtual_key_2"/>

                <Button
                    android:id="@+id/virtual_key_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/virtual_key_3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/virtual_key_4" android:text="@string/virtual_key_4"/>
                <Button android:id="@+id/virtual_key_5" android:text="@string/virtual_key_5"/>
                <Button android:id="@+id/virtual_key_6" android:text="@string/virtual_key_6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/virtual_key_7" android:text="@string/virtual_key_7"/>
                <Button android:id="@+id/virtual_key_8" android:text="@string/virtual_key_8"/>
                <Button android:id="@+id/virtual_key_9" android:text="@string/virtual_key_9"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/virtual_key_star" android:text="@string/virtual_key_star"/>
                <Button android:id="@+id/virtual_key_0" android:text="@string/virtual_key_0"/>
                <Button android:id="@+id/virtual_key_pound" android:text="@string/virtual_key_pound"/>
            </LinearLayout>

            <!-- 🔵 TOP ACTION ROW (unchanged) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/virtual_key_a"
                    android:text="@string/virtual_key_a"/>

                <Button
                    android:id="@+id/virtual_key_menu"
                    android:text="@string/virtual_key_menu"/>

                <Button
                    android:id="@+id/virtual_key_b"
                    android:text="@string/virtual_key_b"/>
            </LinearLayout>

            <!-- 🧭 DPAD MOVED LEFT (was center-right, now logical left grouping) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button android:id="@+id/virtual_key_up" android:text="↑"/>

                    <LinearLayout
                        android:orientation="horizontal">

                        <Button android:id="@+id/virtual_key_left" android:text="←"/>
                        <Button android:id="@+id/virtual_key_f" android:text="●"/>
                        <Button android:id="@+id/virtual_key_right" android:text="→"/>

                    </LinearLayout>

                    <Button android:id="@+id/virtual_key_down" android:text="↓"/>

                </LinearLayout>

                <!-- 🔴 ACTION STAYS RIGHT -->
                <Button
                    android:id="@+id/virtual_key_d"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:text="@string/virtual_key_d"/>
            </LinearLayout>

            <!-- SOFT KEYS (UNCHANGED POSITION LOGICALLY) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/virtual_key_left_soft"
                    android:text="@string/virtual_key_left_soft"/>

                <Button
                    android:id="@+id/virtual_key_up"
                    android:text="@string/virtual_key_up"/>

                <Button
                    android:id="@+id/virtual_key_right_soft"
                    android:text="@string/virtual_key_right_soft"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 🔴 KEY MAPPER OVERLAY (UNCHANGED - REQUIRED FOR JAVA) -->
    <FrameLayout
        android:id="@+id/keyMapperLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#90000000"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/keyMapperPopup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="10dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mapping_dialog_title"/>

            <TextView
                android:id="@+id/keyMapperPopupMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current mapping"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

</FrameLayout>
