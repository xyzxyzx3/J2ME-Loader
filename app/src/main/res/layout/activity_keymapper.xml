<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔴 NUMPAD (HIDDEN) -->
    <LinearLayout
        android:id="@+id/numpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 🔵 L BUTTON -->
    <Button
        android:id="@+id/virtual_key_left_soft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="L"
        android:layout_margin="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 🔵 R BUTTON -->
    <Button
        android:id="@+id/virtual_key_right_soft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="R"
        android:layout_margin="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🎮 DPAD -->
    <LinearLayout
        android:id="@+id/dpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/virtual_key_up"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="↑"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/virtual_key_left"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="←"/>

            <Button
                android:id="@+id/virtual_key_f"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="●"/>

            <Button
                android:id="@+id/virtual_key_right"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="→"/>

        </LinearLayout>

        <Button
            android:id="@+id/virtual_key_down"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="↓"/>

    </LinearLayout>

    <!-- 🔴 ACTION BUTTON -->
    <Button
        android:id="@+id/virtual_key_action"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:text="A"
        android:textSize="18sp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
